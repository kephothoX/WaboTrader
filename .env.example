# ── Telegram ─────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=

# ── LLM / Ollama ─────────────────────────────
# Nosana GPU Endpoint (set after deployment)
OLLAMA_API_URL=https://<nosana-node-id>.node.k8s.prd.nos.ci/api
MODEL_NAME_AT_ENDPOINT=qwen3:8b

# Local development (run `ollama serve` locally)
# OLLAMA_API_URL=http://127.0.0.1:11434/api
# MODEL_NAME_AT_ENDPOINT=qwen3:8b

# ── Solana ───────────────────────────────────
# RPC endpoint — public or paid (Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta

# Wallet private key (base58 encoded) — KEEP SECRET
# Leave empty to run in read-only mode
SOLANA_PRIVATE_KEY=

# ── Trading Mode ─────────────────────────────
# true  = simulate trades (safe for demos, no real funds)
# false = live execution via Jupiter (real funds!)
TRADE_SIMULATION_MODE=true

# ── Perplexity (Market Research) ─────────────
PERPLEXITY_API_KEY=pplx-...

# ── App ──────────────────────────────────────
NODE_ENV=production
ELIZA_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://5ti3xaebkq3wxjdwgwkvmz3htjsifhyhrd4bmxabssqr.node.k8s.prd.nos.ci/ # Must be HTTPS for Telegram Mini App
